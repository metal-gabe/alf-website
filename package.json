{
   "name": "alf-website",
   "version": "1.0.0",
   "private": true,
   "packageManager": "bun@1.3.0",
   "engines": {
      "bun": ">=1.3.0",
      "node": ">=22.11.0"
   },
   "scripts": {
      "dev": "nuxt dev",
      "dev:host": "nuxt dev --host",
      "build": "nuxt build",
      "generate": "nuxt generate",
      "preview": "nuxt preview",
      "——————————————————————————————————————————[ LINT ]——————————————————————————————————————————": "",
      "lint": "eslint . && prettier --check . && stylelint '**/*.{css,vue}'",
      "lint:fix": "eslint . --fix && prettier --write . && stylelint '**/*.{css,vue}' --fix",
      "lint:es": "eslint .",
      "lint:es:fix": "eslint . --fix",
      "lint:prettier": "prettier --check .",
      "lint:prettier:fix": "prettier --write .",
      "lint:style": "stylelint '**/*.{css,vue}'",
      "lint:style:fix": "stylelint '**/*.{css,vue}' --fix",
      "——————————————————————————————————————————[ UTILS ]——————————————————————————————————————————": "",
      "··········································( type-checking )": "",
      "type:check": "echo '=====[ Running the `TYPE:CHECK` script... ]====='; vue-tsc --noEmit",
      "··········································( analysis )": "",
      "circ:check": "echo '=====[ Running the `CIRC:CHECK` script... ]====='; madge --circular .",
      "secrets:check": "echo '=====[ Running the `SECRETS:CHECK` script... ]====='; ggshield secret scan path . --recursive --yes",
      "··········································( cleanup )": "",
      "clean": "rimraf .nuxt .output",
      "clean:full": "rimraf .nuxt .output node_modules",
      "prepare": "husky"
   },
   "dependencies": {
      "nuxt": "^4.2.1",
      "vue": "^3.5.24",
      "vue-router": "^4.5.1"
   },
   "devDependencies": {
      "@tailwindcss/postcss": "^4.1.17",
      "@typescript-eslint/eslint-plugin": "^8.35.1",
      "@typescript-eslint/parser": "^8.35.1",
      "autoprefixer": "^10.4.21",
      "eslint": "^9.38.0",
      "eslint-config-airbnb-base": "^15.0.0",
      "eslint-config-airbnb-typescript": "^18.0.0",
      "eslint-config-prettier": "^10.1.5",
      "eslint-plugin-import": "^2.32.0",
      "eslint-plugin-prettier": "^5.4.1",
      "eslint-plugin-vue": "^9.33.0",
      "husky": "^9.1.7",
      "lint-staged": "^16.1.2",
      "madge": "^8.0.0",
      "postcss": "^8.5.6",
      "prettier": "^3.6.2",
      "rimraf": "^6.0.1",
      "sass": "^1.94.0",
      "stylelint": "^16.25.0",
      "stylelint-config-prettier-scss": "^1.0.0",
      "stylelint-config-standard-scss": "^14.0.0",
      "stylelint-prettier": "^5.0.3",
      "tailwindcss": "^4.1.17",
      "typescript": "^5.9.3",
      "vue-tsc": "^2.2.12"
   },
   "trustedDependencies": [
      "@parcel/watcher"
   ]
}
